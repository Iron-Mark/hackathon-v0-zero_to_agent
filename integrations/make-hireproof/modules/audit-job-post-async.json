{
  "name": "audit-job-post-async",
  "label": "Audit job post async",
  "type": "action",
  "description": "Start a HireProof audit and deliver the completed report to webhook_url.",
  "connection": "hireproof-api",
  "request": {
    "method": "POST",
    "url": "{{connection.baseUrl}}/api/v1/audit",
    "headers": {
      "x-api-key": "{{connection.apiKey}}",
      "Content-Type": "application/json"
    },
    "body": {
      "text": "{{parameters.text}}",
      "location": "{{parameters.location}}",
      "mode": "{{parameters.mode}}",
      "webhook_url": "{{parameters.webhookUrl}}"
    }
  },
  "parameters": [
    {
      "name": "text",
      "label": "Job post or recruiter message",
      "type": "text",
      "required": true,
      "mappable": true
    },
    {
      "name": "location",
      "label": "Location",
      "type": "text",
      "required": false,
      "mappable": true
    },
    {
      "name": "mode",
      "label": "Mode",
      "type": "select",
      "required": true,
      "default": "demo",
      "options": [
        {
          "label": "Demo",
          "value": "demo"
        },
        {
          "label": "Live",
          "value": "live"
        }
      ]
    },
    {
      "name": "webhookUrl",
      "label": "Webhook URL",
      "type": "url",
      "required": true,
      "mappable": true
    }
  ],
  "output": [
    "status",
    "message"
  ]
}
