{
  "name": "hireproof",
  "version": "1.0.0",
  "description": "HireProof is a proof-backed AI agent for checking suspicious job posts before someone applies. A user pastes a job post, recruiter message, or job URL, and the app investigates the opportunity with visible evidence before returning a verdict: **Safe**, **Caution**, or **High-Risk**.",
  "main": "index.js",
  "workspaces": [
    "sdk",
    "integrations/n8n-nodes-hireproof",
    "packages/hireproof-langchain",
    "packages/hireproof-cli"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "next dev -p 3002",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit --project tsconfig.lint.json",
    "cleanup:local-data": "node scripts/cleanup-local-data.mjs",
    "cli": "node packages/hireproof-cli/bin/hireproof.mjs",
    "cli:test": "node --test test/hireproof-cli.test.mjs",
    "icons:extension": "node scripts/generate-extension-icons.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "store:assets": "node scripts/generate-chrome-store-assets.mjs",
    "docker:build": "docker build -t hireproof:local .",
    "docker:run": "docker run --rm -p 3002:3002 --env APP_BASE_URL=http://localhost:3002 --env AGENT_API_KEY=hireproof_agent_demo_key hireproof:local",
    "docker:smoke": "node scripts/smoke-docker.mjs",
    "integrations:build": "node scripts/validate-integrations.mjs --build",
    "integrations:test": "node scripts/validate-integrations.mjs --test",
    "integrations:package": "node scripts/package-integrations.mjs",
    "proof:chat-live": "node scripts/check-live-chat-proof.mjs",
    "proof:chat-live:strict": "node scripts/check-live-chat-proof.mjs --require-live",
    "discord:commands": "node scripts/register-discord-commands.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Iron-Mark/hackathon-v0-zero_to_agent.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Iron-Mark/hackathon-v0-zero_to_agent/issues"
  },
  "homepage": "https://github.com/Iron-Mark/hackathon-v0-zero_to_agent#readme",
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.105",
    "@ai-sdk/openai": "^3.0.53",
    "@chat-adapter/discord": "^4.26.0",
    "@chat-adapter/slack": "^4.26.0",
    "@chat-adapter/state-redis": "^4.26.0",
    "@chat-adapter/telegram": "^4.26.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@zernio/chat-sdk-adapter": "^0.2.3",
    "ai": "^6.0.168",
    "chat": "^4.26.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.11.0",
    "next": "16.2.4",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "typescript": "6.0.3",
    "workflow": "^4.2.4",
    "zod": "^4.3.6"
  },
  "overrides": {
    "devalue": "^5.7.1",
    "postcss": "^8.5.10",
    "undici": "^7.25.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4"
  }
}
