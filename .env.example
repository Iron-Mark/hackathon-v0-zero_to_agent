# HireProof Environment Template
# Copy this file to `.env.local`, then paste real values where needed.
#
# Cost note:
# - Slack app credentials are free within Slack workspace app limits.
# - Upstash Redis has a free tier.
# - WORKFLOW_SECRET is self-generated and free.
# - AI Gateway has monthly free credits, then paid usage if exceeded.

# -----------------------------------------------------------------------------
# 0. App Defaults
# -----------------------------------------------------------------------------

# Local dev:
APP_BASE_URL=http://localhost:3002

# Production example:
# APP_BASE_URL=https://your-vercel-domain.vercel.app

CONTACT_EMAIL=sales@hireproof.com
GITHUB_REPO_URL=https://github.com/Iron-Mark/hackathon-v0-zero_to_agent

# Used by /api/v1/audit and /api/mcp as x-api-key.
AGENT_API_KEY=hireproof_agent_demo_key

# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=paste_generated_session_secret_here

# -----------------------------------------------------------------------------
# 1. AI Model Provider
# -----------------------------------------------------------------------------

# Preferred: Vercel AI Gateway.
AI_GATEWAY_API_KEY=

# Optional alias. This repo accepts either AI_GATEWAY_API_KEY or VERCEL_AI_GATEWAY_API_KEY.
VERCEL_AI_GATEWAY_API_KEY=

# Default Gateway model.
HIREPROOF_MODEL=openai/gpt-4o-mini

# Fallback if AI Gateway is not configured.
MODEL_PROVIDER_KEY=

# Optional legacy/provider-specific key if you test Groq separately.
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# 2. Live Evidence Search
# -----------------------------------------------------------------------------

# Required for live web/news/jobs/local evidence gathering.
SERPAPI_API_KEY=

# -----------------------------------------------------------------------------
# 3. Storage And Rate Limits
# -----------------------------------------------------------------------------

# Upstash REST variables used by existing report storage/rate-limit paths.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Redis URL used by ChatSDK thread state.
# Upstash can provide this in the database connection details.
REDIS_URL=

# -----------------------------------------------------------------------------
# 4. ChatSDK Slack Agent
# -----------------------------------------------------------------------------

# Slack Bot User OAuth Token, usually starts with xoxb-.
SLACK_BOT_TOKEN=

# Slack app Basic Information -> App Credentials -> Signing Secret.
SLACK_SIGNING_SECRET=

# Slack event request URL after deploy:
# https://YOUR_DOMAIN/api/webhooks/slack

# -----------------------------------------------------------------------------
# 5. Vercel Workflow / WDK
# -----------------------------------------------------------------------------

# App-level protection secret for /api/workflows/audit.
# Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WORKFLOW_SECRET=paste_generated_workflow_secret_here
