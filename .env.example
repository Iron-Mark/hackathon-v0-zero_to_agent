# Environment Variables
# Copy this file to `.env.local` and fill in your keys.

# Preferred for live AI-powered claim extraction through Vercel AI Gateway
AI_GATEWAY_API_KEY=
HIREPROOF_MODEL=openai/gpt-4o-mini

# Fallback if you are not using AI Gateway
MODEL_PROVIDER_KEY=your_openai_compatible_api_key

# Required for live web evidence gathering
SERPAPI_API_KEY=your_serpapi_key

# Base URL of the running app (used by the Agent's internal MCP fetch loop)
APP_BASE_URL=http://localhost:3002

# API key for the Headless Agent API (/api/v1/audit) and MCP server (/api/mcp)
# External agents must send this as `x-api-key` header
AGENT_API_KEY=hireproof_agent_demo_key

# Required for signed login sessions in the developer portal
SESSION_SECRET=replace_with_a_long_random_secret

# Public links used by pricing/docs CTAs
CONTACT_EMAIL=sales@hireproof.com
GITHUB_REPO_URL=https://github.com/Iron-Mark/hackathon-v0-zero_to_agent

# Optional: Enable true Distributed L7 DDoS Protection across Serverless Cold Starts
# Create a free Redis database at Upstash (https://upstash.com) and paste keys here:
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Required for live ChatSDK Agents Slack proof.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
REDIS_URL=

# Required to protect and prove live Vercel Workflow route starts.
WORKFLOW_SECRET=
