# Environment Variables
# Copy this file to `.env.local` and fill in your keys.

# Required for live AI-powered claim extraction (OpenAI-compatible)
MODEL_PROVIDER_KEY=your_openai_api_key

# Required for live web evidence gathering
SERPAPI_API_KEY=your_serpapi_key

# Base URL of the running app (used by the Agent's internal MCP fetch loop)
APP_BASE_URL=http://localhost:3000

# API key for the Headless Agent API (/api/v1/audit) and MCP server (/api/mcp)
# External agents must send this as `x-api-key` header
AGENT_API_KEY=hireproof_agent_demo_key
